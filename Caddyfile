# Reverse proxy + automatic HTTPS for the BLC Website Audit app.
# Caddy obtains and renews a Let's Encrypt cert for the domain automatically
# (ports 80 + 443 must be reachable — they are open in the Linode firewall).

ai.builderleadconverter.com {
	encode zstd gzip

	# API: strip the /api prefix, then forward to FastAPI.
	# e.g. https://.../api/audits  ->  http://api:8000/audits
	handle_path /api/* {
		reverse_proxy api:8000
	}

	# Everything else -> the Next.js operator UI.
	handle {
		reverse_proxy frontend:3000
	}
}
