# BLC Website Audit - Local Environment Example
# Copy this file to .env for local development.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# App mode
# -----------------------------------------------------------------------------
APP_ENV=local
APP_NAME=blc-website-audit
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
API_CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="BLC Website Audit"
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Clerk authentication
# Frontend uses the publishable + secret keys; the API verifies session tokens
# against CLERK_ISSUER's JWKS. Leave CLERK_ISSUER EMPTY to DISABLE API auth
# (local dev / tests). In production set all four.
#   CLERK_ISSUER = https://<your-instance>.clerk.accounts.dev  (derive from the pk_ key)
#   CLERK_AUTHORIZED_PARTIES = comma-separated app origins, e.g. https://ai.builderleadconverter.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ISSUER=
CLERK_AUTHORIZED_PARTIES=

# -----------------------------------------------------------------------------
# PostgreSQL
# Used by the API and worker.
# The POSTGRES_* values are also useful for Docker Compose.
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=blc_website_audit
POSTGRES_USER=blc
POSTGRES_PASSWORD=change-me-local
DATABASE_URL=postgresql+psycopg://blc:change-me-local@localhost:5432/blc_website_audit

# -----------------------------------------------------------------------------
# Redis / Celery
# Used for async audit jobs.
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
AUDIT_ENQUEUE_ENABLED=true
# Worker task limits (seconds). The soft limit must be < the hard limit so it
# fires first and the job is marked FAILED instead of leaving a stuck row.
CELERY_TASK_TIME_LIMIT_SECONDS=1800
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=1740

# -----------------------------------------------------------------------------
# Local report storage
# Phase 1 stores generated PDFs and screenshots on the local filesystem.
# -----------------------------------------------------------------------------
LOCAL_REPORT_STORAGE_DIR=./storage/reports
LOCAL_SCREENSHOT_STORAGE_DIR=./storage/screenshots
LOCAL_TOOL_EXPORT_STORAGE_DIR=./storage/tool_exports
# Delete reports/screenshots/tool-exports older than this many days when
# scripts/cleanup_storage.py runs (cron on the host; no in-app scheduler). 0 = keep forever.
STORAGE_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# Observability (optional)
# Empty SENTRY_DSN => error reporting disabled (local/dev/tests). Set it in
# production to capture API + worker exceptions in Sentry.
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Operational alerting (scripts/health_alert.py, run from cron). Empty webhook => disabled
# (it just logs findings). Slack/Discord/generic webhook accepting {"text": "..."}.
ALERT_WEBHOOK_URL=
ALERT_FAILED_AUDITS_THRESHOLD=5
ALERT_STUCK_AUDIT_MINUTES=60

# PostgreSQL backups (scripts/backup_db.py, run from cron) -> timestamped .sql.gz.
BACKUP_STORAGE_DIR=./storage/backups
BACKUP_RETENTION_DAYS=14
PG_DUMP_PATH=pg_dump

# -----------------------------------------------------------------------------
# Social data provider (Apify) — Phase 2 social audit (free-tier credits).
# Empty token => the social collector skips. Get a token at apify.com
# (Settings -> Integrations -> API token). Treat it as a secret; never commit a real value.
# -----------------------------------------------------------------------------
APIFY_API_TOKEN=
APIFY_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# YouTube Data API v3 — free public-data backend for the social audit (no OAuth).
# Empty key => the YouTube backend skips gracefully. Get a key in Google Cloud:
# create/select a project -> enable "YouTube Data API v3" -> Credentials -> API key.
# Free quota is ~10,000 units/day; one channel audit costs only a few units.
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=
YOUTUBE_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# OpenAI / ChatGPT commentary
# Phase 1 commentary is fully DETERMINISTIC (apps/worker/stages/content_plan.py);
# OpenAI is NOT called in Phase 1 — these keys feed dormant Phase-2 polish
# scaffolding only, so leaving them blank is the supported default.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Set this to the exact OpenAI model ID approved for implementation (Phase 2).
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_SECONDS=60

# -----------------------------------------------------------------------------
# Google PageSpeed Insights
# Required for Lighthouse/Core Web Vitals style performance data.
# -----------------------------------------------------------------------------
GOOGLE_PSI_API_KEY=
PSI_SCOPE=all_crawled_pages
PSI_MAX_PAGES=10
PSI_TIMEOUT_SECONDS=60
PSI_MAX_RETRIES=3
PSI_CACHE_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# Technical crawl (site health sweep + optional Screaming Frog)
#
# The built-in site health sweep is the default technical crawl: it status-checks
# every URL the audit discovered (internal links, outbound links, sitemap.xml)
# with plain HTTP requests and computes duplicate/missing metadata over the
# rendered pages. It needs no licence, no JVM, and runs in Docker — this is what
# production uses.
#
# Screaming Frog is an OPTIONAL alternative for a machine that has the desktop
# app + a paid licence (its CLI mode is licence-gated, licences are per-user,
# and the JVM wants 2-4 GB RAM, so it is NOT installed in the Docker images).
# When enabled and it completes, its data replaces the sweep for that audit;
# when it fails, the sweep runs as fallback. The timeout is clamped at runtime
# to fit inside CELERY_TASK_SOFT_TIME_LIMIT_SECONDS minus a 2-minute reserve.
# -----------------------------------------------------------------------------
SITE_HEALTH_ENABLED=true
SITE_HEALTH_MAX_INTERNAL_URLS=150
SITE_HEALTH_MAX_EXTERNAL_URLS=50
SITE_HEALTH_CHECK_EXTERNAL_LINKS=true
SITE_HEALTH_CONCURRENCY=8
SITE_HEALTH_REQUEST_TIMEOUT_SECONDS=10
SITE_HEALTH_TOTAL_BUDGET_SECONDS=180
SITE_HEALTH_SITEMAP_MAX_URLS=500

SCREAMING_FROG_ENABLED=false
SCREAMING_FROG_BINARY=
SCREAMING_FROG_OUTPUT_DIR=./storage/tool_exports/screaming_frog
SCREAMING_FROG_TIMEOUT_SECONDS=600
SCREAMING_FROG_EXPORT_TABS=Internal:All,Response Codes:Client Error (4xx)

# -----------------------------------------------------------------------------
# Google Search Console
# Optional verified-property enrichment. Uses official Google APIs; never scrapes
# search.google.com UI pages. Requires OAuth consent and property access.
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/google/search-console/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/audits
# Signs the OAuth `state` parameter (CSRF protection). Optional for a
# single-process API (an ephemeral per-process secret is used); set a long
# random string if the API ever runs with multiple replicas.
GOOGLE_OAUTH_STATE_SECRET=
GSC_DEFAULT_DATE_RANGE_DAYS=90
GSC_ROW_LIMIT=25000
URL_INSPECTION_MAX_URLS=20

# -----------------------------------------------------------------------------
# Playwright crawler settings
# -----------------------------------------------------------------------------
CRAWLER_USER_AGENT="BLC-Audit-Bot/1.0 (+https://builderleadconverter.com/audit-bot)"
CRAWLER_MAX_PAGES=10
CRAWLER_CONCURRENCY=3
CRAWLER_PAGE_TIMEOUT_SECONDS=30
CRAWLER_RESPECT_ROBOTS_TXT=true
CRAWLER_SCREENSHOTS_ENABLED=true
CRAWLER_ALLOW_PRIVATE_HOSTS=false
# Request-level SSRF guard: validate every sub-resource/redirect the headless browser
# fetches against the private/loopback/metadata-IP block-list (closes the mid-render
# SSRF gap). Auto-disabled when CRAWLER_ALLOW_PRIVATE_HOSTS=true (local/QA crawls).
CRAWLER_INTERCEPT_REQUESTS=true
# Optional local fallback when Playwright's default headless-shell binary is unavailable.
CRAWLER_CHROMIUM_EXECUTABLE_PATH=

# -----------------------------------------------------------------------------
# Scoring and reports
# -----------------------------------------------------------------------------
RUBRIC_SEO_PATH=./rubrics/seo.yaml
RUBRIC_UXUI_PATH=./rubrics/uxui.yaml
RUBRIC_COMPOSITE_PATH=./rubrics/composite.yaml
COMMENTARY_SYSTEM_PROMPT_PATH=./prompts/commentary_system.md
COMMENTARY_USER_PROMPT_PATH=./prompts/commentary_user.md
BRAND_CONFIG_PATH=./brand/blc.yaml
REPORT_TEMPLATE_PATH=./templates/report.html
REPORT_CSS_PATH=./templates/report.css
