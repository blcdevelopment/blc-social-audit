# BLC Website Audit - Local Environment Example
# Copy this file to .env for local development.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# App mode
# -----------------------------------------------------------------------------
APP_ENV=local
APP_NAME=blc-website-audit
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
API_CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="BLC Website Audit"
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# PostgreSQL
# Used by the API and worker.
# The POSTGRES_* values are also useful for Docker Compose.
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=blc_website_audit
POSTGRES_USER=blc
POSTGRES_PASSWORD=change-me-local
DATABASE_URL=postgresql+psycopg://blc:change-me-local@localhost:5432/blc_website_audit

# -----------------------------------------------------------------------------
# Redis / Celery
# Used for async audit jobs.
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
AUDIT_ENQUEUE_ENABLED=true
# Worker task limits (seconds). The soft limit must be < the hard limit so it
# fires first and the job is marked FAILED instead of leaving a stuck row.
CELERY_TASK_TIME_LIMIT_SECONDS=900
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=840

# -----------------------------------------------------------------------------
# Local report storage
# Phase 1 stores generated PDFs and screenshots on the local filesystem.
# -----------------------------------------------------------------------------
LOCAL_REPORT_STORAGE_DIR=./storage/reports
LOCAL_SCREENSHOT_STORAGE_DIR=./storage/screenshots

# -----------------------------------------------------------------------------
# OpenAI / ChatGPT commentary
# Direct OpenAI access is the Phase 1 local-first default.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Set this to the exact OpenAI model ID approved for implementation.
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_SECONDS=60

# -----------------------------------------------------------------------------
# Google PageSpeed Insights
# Required for Lighthouse/Core Web Vitals style performance data.
# -----------------------------------------------------------------------------
GOOGLE_PSI_API_KEY=
PSI_SCOPE=all_crawled_pages
PSI_MAX_PAGES=10
PSI_TIMEOUT_SECONDS=60
PSI_MAX_RETRIES=3
PSI_CACHE_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# Playwright crawler settings
# -----------------------------------------------------------------------------
CRAWLER_USER_AGENT="BLC-Audit-Bot/1.0 (+https://builderleadconverter.com/audit-bot)"
CRAWLER_MAX_PAGES=10
CRAWLER_CONCURRENCY=3
CRAWLER_PAGE_TIMEOUT_SECONDS=30
CRAWLER_RESPECT_ROBOTS_TXT=true
CRAWLER_SCREENSHOTS_ENABLED=true
CRAWLER_ALLOW_PRIVATE_HOSTS=false
# Optional local fallback when Playwright's default headless-shell binary is unavailable.
CRAWLER_CHROMIUM_EXECUTABLE_PATH=

# -----------------------------------------------------------------------------
# Scoring and reports
# -----------------------------------------------------------------------------
RUBRIC_SEO_PATH=./rubrics/seo.yaml
RUBRIC_UXUI_PATH=./rubrics/uxui.yaml
RUBRIC_COMPOSITE_PATH=./rubrics/composite.yaml
COMMENTARY_SYSTEM_PROMPT_PATH=./prompts/commentary_system.md
COMMENTARY_USER_PROMPT_PATH=./prompts/commentary_user.md
BRAND_CONFIG_PATH=./brand/blc.yaml
REPORT_TEMPLATE_PATH=./templates/report.html
REPORT_CSS_PATH=./templates/report.css
