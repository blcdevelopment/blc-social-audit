# BLC Website Audit - Local Environment Example
# Copy this file to .env for local development.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# App mode
# -----------------------------------------------------------------------------
APP_ENV=local
APP_NAME=blc-website-audit
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
API_CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="BLC Website Audit"
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Clerk authentication
# Frontend uses the publishable + secret keys; the API verifies session tokens
# against CLERK_ISSUER's JWKS. Leave CLERK_ISSUER EMPTY to DISABLE API auth
# (local dev / tests). In production set all four.
#   CLERK_ISSUER = https://<your-instance>.clerk.accounts.dev  (derive from the pk_ key)
#   CLERK_AUTHORIZED_PARTIES = comma-separated app origins, e.g. https://ai.builderleadconverter.com
#   CLERK_ALLOWED_SUBJECTS = optional comma-separated Clerk user ids (the token `sub`, e.g.
#     user_2ab...,user_3cd...) allowed to use the API. Empty => any valid token is accepted.
#     Set it to your operators' ids (defense-in-depth) so a stranger who self-registers on the
#     Clerk instance still can't reach the audit endpoints. PROD should ALSO set the Clerk
#     instance to invitation-only.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ISSUER=
CLERK_AUTHORIZED_PARTIES=
CLERK_ALLOWED_SUBJECTS=

# -----------------------------------------------------------------------------
# PostgreSQL
# Used by the API and worker.
# The POSTGRES_* values are also useful for Docker Compose.
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=blc_website_audit
POSTGRES_USER=blc
POSTGRES_PASSWORD=change-me-local
DATABASE_URL=postgresql+psycopg://blc:change-me-local@localhost:5432/blc_website_audit

# -----------------------------------------------------------------------------
# Redis / Celery
# Used for async audit jobs.
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
AUDIT_ENQUEUE_ENABLED=true
# Worker task limits (seconds). The soft limit must be < the hard limit so it
# fires first and the job is marked FAILED instead of leaving a stuck row.
CELERY_TASK_TIME_LIMIT_SECONDS=1800
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=1740

# -----------------------------------------------------------------------------
# Local report storage
# Phase 1 stores generated PDFs and screenshots on the local filesystem.
# -----------------------------------------------------------------------------
LOCAL_REPORT_STORAGE_DIR=./storage/reports
LOCAL_SCREENSHOT_STORAGE_DIR=./storage/screenshots
LOCAL_TOOL_EXPORT_STORAGE_DIR=./storage/tool_exports
# Delete reports/screenshots/tool-exports older than this many days when
# scripts/cleanup_storage.py runs (cron on the host; no in-app scheduler). 0 = keep forever.
STORAGE_RETENTION_DAYS=90
# Lifetime in days of read-only report share links minted by POST /audits/{id}/share
# (default 7, range 1-365).
SHARE_LINK_TTL_DAYS=7

# -----------------------------------------------------------------------------
# Observability (optional)
# Empty SENTRY_DSN => error reporting disabled (local/dev/tests). Set it in
# production to capture API + worker exceptions in Sentry.
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Operational alerting (scripts/health_alert.py, run from cron). Empty webhook => disabled
# (it just logs findings). Slack/Discord/generic webhook accepting {"text": "..."}.
ALERT_WEBHOOK_URL=
ALERT_FAILED_AUDITS_THRESHOLD=5
ALERT_STUCK_AUDIT_MINUTES=60

# PostgreSQL backups (scripts/backup_db.py, run from cron) -> timestamped .sql.gz.
BACKUP_STORAGE_DIR=./storage/backups
BACKUP_RETENTION_DAYS=14
PG_DUMP_PATH=pg_dump

# -----------------------------------------------------------------------------
# Social data provider (Apify) — Phase 2 social audit (free-tier credits).
# Empty token => the social collector skips. Get a token at apify.com
# (Settings -> Integrations -> API token). Treat it as a secret; never commit a real value.
# -----------------------------------------------------------------------------
APIFY_API_TOKEN=
APIFY_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# YouTube Data API v3 — free public-data backend for the social audit (no OAuth).
# Empty key => the YouTube backend skips gracefully. Get a key in Google Cloud:
# create/select a project -> enable "YouTube Data API v3" -> Credentials -> API key.
# Free quota is ~10,000 units/day; one channel audit costs only a few units.
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=
YOUTUBE_TIMEOUT_SECONDS=30
# Opt-in connected-channel metrics (owner consent): when true, the Google OAuth consent used
# for Search Console also requests the YouTube Analytics read-only scopes, and audits that
# include a YouTube handle attach the CONNECTED account's channel metrics (views, watch time,
# retention, subscriber flow, traffic sources) as a "Connected YouTube analytics" report block.
# The existing /google/search-console/connect flow is the connect affordance. Default false =>
# the consent screen and the public-data audit path are byte-identical.
YOUTUBE_ANALYTICS_CONNECT_ENABLED=false

# -----------------------------------------------------------------------------
# Google Places API (New) — PUBLIC Google Business Profile data for the combined audit
# (address, phone, category, star rating, review count, website). No owner consent needed
# (contrast the owner-only Google Business Profile API). Enable "Places API (New)" in Google
# Cloud, create an API key, and put it here. Billed per request but Google gives a free monthly
# allotment per SKU (Enterprise ~1,000/mo) — effectively $0 at audit volume. Empty key => the
# Google enrichment skips gracefully and the website/combined report is byte-identical.
# -----------------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_TIMEOUT_SECONDS=30

# Auto-detect social profile links from the crawled page (footer/header icons) to fill any
# Instagram/Facebook/YouTube field the operator left blank (explicit handles always win). For a
# plain website audit this promotes it to a combined one (social section + Overall Readiness
# appended). Only platforms whose provider credential (APIFY_API_TOKEN / YOUTUBE_API_KEY) is
# configured are back-filled, and the promotion happens only when the social collection actually
# produces data — without keys, or on a failed collection, a website audit stays website-only.
# Default true; set false to stop the extra Apify/YouTube scrapes (kill-switch).
SOCIAL_AUTODISCOVERY_ENABLED=true

# Competitor benchmarking (P2-26 / SMWA-79 — Epic P2-E5 Enrichment, v3). DEFERRED: presents the
# audited scores relative to competitor / industry baselines from a paid provider (SEMrush / Ahrefs
# / Similarweb — no free reliable source). OFF by default, and there is no live vendor client yet,
# so the benchmark step SKIPS gracefully unless BENCHMARK_ENABLED is set, BENCHMARK_PROVIDER names a
# supported vendor, and BENCHMARK_API_KEY is configured — and even then it no-ops until the vendor
# client is implemented and its recurring cost is approved (the ticket's acceptance gate). Until
# then the report is byte-identical and no cost is incurred. Benchmarking never changes a score.
BENCHMARK_ENABLED=false
BENCHMARK_PROVIDER=          # "" | semrush | ahrefs | similarweb
BENCHMARK_API_KEY=

# -----------------------------------------------------------------------------
# OpenAI / ChatGPT commentary
# Phase 1 commentary is fully DETERMINISTIC (apps/worker/stages/content_plan.py);
# OpenAI is NOT called in Phase 1 — these keys feed dormant Phase-2 polish
# scaffolding only, so leaving them blank is the supported default.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Set this to the exact OpenAI model ID approved for implementation (Phase 2).
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_SECONDS=60

# -----------------------------------------------------------------------------
# Google PageSpeed Insights
# Required for Lighthouse/Core Web Vitals style performance data.
# -----------------------------------------------------------------------------
GOOGLE_PSI_API_KEY=
PSI_SCOPE=all_crawled_pages
PSI_MAX_PAGES=10
PSI_TIMEOUT_SECONDS=60
PSI_MAX_RETRIES=3
PSI_CACHE_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# Technical crawl (site health sweep + optional Screaming Frog)
#
# The built-in site health sweep is the default technical crawl: it status-checks
# every URL the audit discovered (internal links, outbound links, sitemap.xml)
# with plain HTTP requests and computes duplicate/missing metadata over the
# rendered pages. It needs no licence, no JVM, and runs in Docker — this is what
# production uses.
#
# Screaming Frog is an OPTIONAL alternative for a machine that has the desktop
# app + a paid licence (its CLI mode is licence-gated, licences are per-user,
# and the JVM wants 2-4 GB RAM, so it is NOT installed in the Docker images).
# When enabled and it completes, its data replaces the sweep for that audit;
# when it fails, the sweep runs as fallback. The timeout is clamped at runtime
# to fit inside CELERY_TASK_SOFT_TIME_LIMIT_SECONDS minus a 2-minute reserve.
# -----------------------------------------------------------------------------
SITE_HEALTH_ENABLED=true
SITE_HEALTH_MAX_INTERNAL_URLS=150
SITE_HEALTH_MAX_EXTERNAL_URLS=50
SITE_HEALTH_CHECK_EXTERNAL_LINKS=true
SITE_HEALTH_CONCURRENCY=8
SITE_HEALTH_REQUEST_TIMEOUT_SECONDS=10
SITE_HEALTH_TOTAL_BUDGET_SECONDS=180
SITE_HEALTH_SITEMAP_MAX_URLS=500
# Politeness is applied PER TARGET HOST: the audited site gets at most this many concurrent
# requests with jittered spacing between same-host requests (so its firewall doesn't
# rate-limit the checker into false "dead link" findings), while outbound links on distinct
# third-party hosts run in parallel up to SITE_HEALTH_CONCURRENCY with no artificial spacing;
# the breaker stops the run after N consecutive network failures and marks the source
# partial (reason bot_blocked) instead of over-claiming.
SITE_HEALTH_PER_HOST_CONCURRENCY=2
SITE_HEALTH_REQUEST_DELAY_MS=750
SITE_HEALTH_BREAKER_THRESHOLD=5

SCREAMING_FROG_ENABLED=false
SCREAMING_FROG_BINARY=
SCREAMING_FROG_OUTPUT_DIR=./storage/tool_exports/screaming_frog
SCREAMING_FROG_TIMEOUT_SECONDS=600
SCREAMING_FROG_EXPORT_TABS=Internal:All,Response Codes:Client Error (4xx)

# -----------------------------------------------------------------------------
# Google Search Console
# Optional verified-property enrichment. Uses official Google APIs; never scrapes
# search.google.com UI pages. Requires OAuth consent and property access.
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/google/search-console/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/audits
# Signs the OAuth `state` parameter (CSRF protection). Optional for a
# single-process API (an ephemeral per-process secret is used); set a long
# random string if the API ever runs with multiple replicas.
GOOGLE_OAUTH_STATE_SECRET=
GSC_DEFAULT_DATE_RANGE_DAYS=90
GSC_ROW_LIMIT=25000
URL_INSPECTION_MAX_URLS=20
# "Ranking opportunity" forecast knobs. AIO prevalence = share of audited-niche queries assumed
# to surface an AI Overview (raising it makes every forecast more conservative); cap multiple =
# no scenario may exceed this multiple of the site's current monthly clicks. Both applied values
# are recorded in the stored estimate, so tuned deployments stay self-describing.
GSC_OPPORTUNITY_AIO_PREVALENCE=0.40
GSC_OPPORTUNITY_CAP_MULTIPLE=3.0

# -----------------------------------------------------------------------------
# Playwright crawler settings
# -----------------------------------------------------------------------------
CRAWLER_USER_AGENT="BLC-Audit-Bot/1.0 (+https://builderleadconverter.com/audit-bot)"
CRAWLER_MAX_PAGES=10
CRAWLER_CONCURRENCY=3
CRAWLER_PAGE_TIMEOUT_SECONDS=30
CRAWLER_RESPECT_ROBOTS_TXT=true
CRAWLER_SCREENSHOTS_ENABLED=true
CRAWLER_ALLOW_PRIVATE_HOSTS=false
# Request-level SSRF guard: validate every sub-resource/redirect the headless browser
# fetches against the private/loopback/metadata-IP block-list (closes the mid-render
# SSRF gap). Auto-disabled when CRAWLER_ALLOW_PRIVATE_HOSTS=true (local/QA crawls).
CRAWLER_INTERCEPT_REQUESTS=true
# Optional local fallback when Playwright's default headless-shell binary is unavailable.
CRAWLER_CHROMIUM_EXECUTABLE_PATH=

# -----------------------------------------------------------------------------
# Optional advisory accessibility pass (axe-core) — default OFF
# -----------------------------------------------------------------------------
# When enabled, axe-core runs against the live rendered DOM during the crawl and its findings
# are shown as an ADVISORY report section (colour contrast, computed ARIA, etc.). The results
# NEVER affect the deterministic score, so scores stay reproducible whether this is on or off.
# Missing asset / scan error / timeout => the audit completes normally with no advisory section.
ACCESSIBILITY_ADVISORY_ENABLED=false
# Vendored, version-pinned axe-core (offline; no CDN/Node dependency).
ACCESSIBILITY_AXE_SCRIPT_PATH=./vendor/axe-core/axe.min.js
ACCESSIBILITY_AXE_TIMEOUT_SECONDS=30
ACCESSIBILITY_MAX_EXAMPLES_PER_ISSUE=5
# color-contrast is the most expensive / least reproducible axe rule; set false to drop it.
ACCESSIBILITY_RUN_CONTRAST=true

# -----------------------------------------------------------------------------
# Scoring and reports
# -----------------------------------------------------------------------------
# Cap on rendered findings per report section; recommendations pair 1:1 with the rendered
# findings, so this is the only truncation knob for both lists.
COMMENTARY_MAX_FINDINGS_PER_SECTION=5

RUBRIC_SEO_PATH=./rubrics/seo.yaml
RUBRIC_UXUI_PATH=./rubrics/uxui.yaml
RUBRIC_COMPOSITE_PATH=./rubrics/composite.yaml
RUBRIC_SOCIAL_PATH=./rubrics/social.yaml
# Combined-audit Overall Lead-Gen Readiness weights (website composite + Social Score).
RUBRIC_OVERALL_PATH=./rubrics/overall.yaml
COMMENTARY_SYSTEM_PROMPT_PATH=./prompts/commentary_system.md
COMMENTARY_USER_PROMPT_PATH=./prompts/commentary_user.md
BRAND_CONFIG_PATH=./brand/blc.yaml
REPORT_TEMPLATE_PATH=./templates/report.html
REPORT_CSS_PATH=./templates/report.css
